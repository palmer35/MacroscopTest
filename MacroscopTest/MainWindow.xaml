<Window x:Class="MacroscopTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:MacroscopTest.ViewModels"
        xmlns:views="clr-namespace:MacroscopTest.Views"
        Title="MacroscopTest"
        Width="960"
        Height="620"
        MinWidth="960"
        MinHeight="620"
        Background="#FAFAFA"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      Margin="0,0,0,20"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ImageSlotView />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="1"
                Margin="0,0,0,14"
                Style="{StaticResource RoundedButtonStyle}"
                Command="{Binding LoadAllCommand}"
                Content="LOAD ALL" />

        <Grid Grid.Row="2"
              Height="22">
            <ProgressBar Minimum="0"
                         Maximum="{Binding SlotsCount}"
                         Height="22"
                         Foreground="#A9C3E6"
                         Background="White"
                         Value="{Binding ActiveLoadsCount, Mode=OneWay}" />

            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#5B6472"
                       IsHitTestVisible="False"
                       Text="PROGRESS" />

            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#6B7280"
                       Margin="0,0,8,0"
                       IsHitTestVisible="False"
                       Text="{Binding ActiveLoadsSummary}" />
        </Grid>
    </Grid>
</Window>
