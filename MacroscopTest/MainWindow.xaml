<Window x:Class="MacroscopTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:MacroscopTest.ViewModels"
        xmlns:views="clr-namespace:MacroscopTest.Views"
        Title="Macroscop Test"
        Width="960"
        Height="620"
        MinWidth="860"
        MinHeight="560"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalAlignment="Top"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ImageSlotView />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="1"
                Height="36"
                Margin="10,16,10,12"
                Padding="12,8"
                Command="{Binding LoadAllCommand}"
                Content="LOAD ALL" />

        <Grid Grid.Row="2"
              Height="18"
              Margin="10,0,10,0">
            <ProgressBar Minimum="0"
                         Maximum="3"
                         Value="{Binding ActiveLoadsCount, Mode=OneWay}" />

            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       Text="PROGRESS" />

            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#6B7280"
                       IsHitTestVisible="False"
                       Text="{Binding ActiveLoadsCount, StringFormat={}{0} / 3}" />
        </Grid>
    </Grid>
</Window>


