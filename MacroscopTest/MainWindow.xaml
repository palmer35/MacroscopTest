<Window x:Class="MacroscopTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:MacroscopTest.ViewModels"
        xmlns:views="clr-namespace:MacroscopTest.Views"
        Title="MacroscopTest"
        Width="960"
        Height="620"
        MinWidth="960"
        MinHeight="620"
        Background="#FAFAFA"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0"
                      Margin="0,0,0,12"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ItemsSource="{Binding Slots}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"
                                 Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="VerticalAlignment" Value="Stretch" />
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <views:ImageSlotView />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="1"
                Margin="0,0,0,14"
                Style="{StaticResource RoundedButtonStyle}"
                Command="{Binding LoadAllCommand}"
                Content="LOAD ALL" />

        <Grid Grid.Row="2"
              Height="22">
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="22"
                         Foreground="#A9C3E6"
                         Background="White"
                         Value="{Binding OverallDownloadProgress, Mode=OneWay}" />

            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#5B6472"
                       IsHitTestVisible="False"
                       Text="PROGRESS" />

            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#374151"
                       Margin="0,0,8,0"
                       IsHitTestVisible="False"
                       Text="{Binding ProgressSummary}" />
        </Grid>
    </Grid>
</Window>


