<Window x:Class="MacroscopTest.Views.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Preview"
        Width="1000"
        Height="720"
        MinWidth="640"
        MinHeight="480"
        Background="#1F2328"
        WindowStartupLocation="CenterOwner"
        Loaded="OnLoaded">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="10,8"
                Background="#2D333B">
            <StackPanel Orientation="Horizontal">
                <Button Width="110"
                        Margin="0,0,8,0"
                        Padding="10,4"
                        Click="OnFitClick"
                        Content="Fit to screen" />

                <Button Width="42"
                        Margin="0,0,8,0"
                        Padding="10,4"
                        Click="OnZoomOutClick"
                        Content="-" />

                <Button Width="42"
                        Margin="0,0,8,0"
                        Padding="10,4"
                        Click="OnZoomInClick"
                        Content="+" />

                <Button Width="90"
                        Margin="0,0,12,0"
                        Padding="10,4"
                        Click="OnActualSizeClick"
                        Content="Actual size" />

                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#D0D7DE"
                           Text="Loading..." />
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="ImageScrollViewer"
                      Background="#1F2328"
                      HorizontalScrollBarVisibility="Disabled"
                      PreviewMouseLeftButtonDown="OnImageScrollViewerPreviewMouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="OnImageScrollViewerPreviewMouseLeftButtonUp"
                      PreviewMouseMove="OnImageScrollViewerPreviewMouseMove"
                      PreviewMouseWheel="OnImageScrollViewerPreviewMouseWheel"
                      SizeChanged="OnImageScrollViewerSizeChanged"
                      VerticalScrollBarVisibility="Disabled">
            <Image x:Name="PreviewImage"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Stretch="Uniform" />
        </ScrollViewer>
    </DockPanel>
</Window>
