<UserControl x:Class="MacroscopTest.Views.ImageSlotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:MacroscopTest.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ImageSlotViewModel, IsDesignTimeCreatable=False}">
    <Border Width="250"
            Margin="14,6,14,18"
            Padding="14"
            Background="White"
            BorderBrush="#D0D7DE"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel>
            <Border Height="200"
                    Margin="0,0,0,12"
                    Padding="10"
                    Background="#F5F5F5"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Image Source="{Binding Image}"
                           Stretch="Uniform">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Opacity" Value="0.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#6B7280"
                               Text="IMAGE">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        </TextBlock>

                    <ProgressBar Height="8"
                                 Margin="16,0"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True"
                                 Foreground="#9DB7D7">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,14">
                <TextBox Style="{StaticResource RoundedTextBoxStyle}"
                         HorizontalContentAlignment="Left"
                         Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#8A8F98"
                           IsHitTestVisible="False"
                           Text="URL">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Url}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <StackPanel Margin="0,0,0,10">
                <Button Margin="0,0,0,8"
                        Style="{StaticResource RoundedButtonStyle}"
                        Command="{Binding LoadCommand}"
                        Content="START" />

                <Button Style="{StaticResource RoundedButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Content="STOP" />
            </StackPanel>

            <TextBlock Margin="0,0,0,4"
                       MinHeight="20"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#6B7280"
                       Text="{Binding StatusText}" />

            <TextBlock MinHeight="20"
                       Foreground="#C62828"
                       Text="{Binding ErrorText}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
